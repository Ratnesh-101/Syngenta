# Backend environment variables
# Copy this file to .env and fill in the values.
# Never commit .env to git (the root .gitignore excludes .env and .env.*).

# ---------- OpenAI ----------
# Used by the LLM briefing and explainer endpoints (gpt-4o-mini).
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ---------- JWT ----------
# Used to sign authentication tokens. Generate a fresh random string for production.
# A 48-character random alphanumeric string is recommended.
JWT_SECRET=replace-with-48-char-random-string-do-not-use-this-value
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ---------- OTP settings ----------
# Stage 1: OTP delivery is stubbed (demo phone 9999999999 is pre-seeded).
# Stage 2 commitment: Email OTP via SendGrid (no Indian DLT / WABA compliance needed).
DEV_MODE=true
OTP_PROVIDER=console
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_SEND_COOLDOWN_SECONDS=60
OTP_MAX_SENDS_PER_HOUR=10
OTP_MAX_VERIFY_ATTEMPTS=5

# ---------- Google OAuth ----------
# OAuth 2.0 client ID for "Sign in with Google" — same value as VITE_GOOGLE_CLIENT_ID in frontend.
# Get one at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com