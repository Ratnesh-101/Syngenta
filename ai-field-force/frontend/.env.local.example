# Frontend environment variables (Vite reads these at build time)
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git (the root .gitignore excludes .env and .env.*).
#
# NOTE: VITE_* variables are baked into the public JavaScript bundle and visible
# to any user inspecting the browser. They are configuration, not secrets.
# Real secrets (OpenAI key, JWT signing key) belong in the BACKEND .env, never here.

# ---------- Backend URL ----------
# Where the React app sends API requests.
# Local development:  http://localhost:8000
# Live deployment:    https://kheti-compass.onrender.com
VITE_API_BASE_URL=http://localhost:8000

# ---------- Mock mode ----------
# If 'true', the frontend uses hardcoded mock data instead of calling the backend.
# Useful for frontend-only development with no backend running. Set to 'false' for normal use.
VITE_MOCK_MODE=false

# ---------- Google OAuth ----------
# OAuth 2.0 client ID for "Sign in with Google" — must match GOOGLE_CLIENT_ID in backend.
# Get one at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com